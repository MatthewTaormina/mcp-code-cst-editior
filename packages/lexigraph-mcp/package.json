{
  "name": "@lexigraph/mcp",
  "version": "0.0.0",
  "description": "MCP server exposing structured code editing via @lexigraph/core",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "lexigraph-mcp": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "start": "node dist/cli.js"
  },
  "dependencies": {
    "@lexigraph/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "chokidar": "^4.0.1",
    "picomatch": "^4.0.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/picomatch": "^3.0.2"
  }
}
